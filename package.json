{
  "name": "laundry",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -H 0.0.0.0 -p 3888",
    "build": "next build",
    "build:production": "cross-env NODE_ENV=production NEXT_PUBLIC_ENVIRONMENT=production next build",
    "start": "next start -H 0.0.0.0 -p 3888",
    "start:production": "cross-env NODE_ENV=production NEXT_PUBLIC_ENVIRONMENT=production next start -H 0.0.0.0 -p 3888",
    "serve": "npm run build:production && npm run start:production",
    "lint": "next lint",
    "export": "next export",
    "tunnel": "npx ngrok http 3888",
    "tunnel:localtunnel": "npx localtunnel --port 3888",
    "tunnel:cloudflare": "npx cloudflared tunnel --url http://localhost:3888",
    "check-env": "node scripts/check-env.js",
    "setup-api-key": "node scripts/setup-google-maps-key.js"
  },
  "dependencies": {
    "@adyen/adyen-web": "^5.71.3",
    "@heroui/react": "2.7.6",
    "@heroui/system": "2.4.17",
    "@heroui/theme": "2.4.17",
    "@react-google-maps/api": "^2.20.6",
    "@reduxjs/toolkit": "^2.8.2",
    "@stripe/react-stripe-js": "^3.7.0",
    "@stripe/stripe-js": "^4.0.0",
    "@tanstack/react-query": "^5.90.10",
    "@tanstack/react-query-devtools": "^5.91.0",
    "@types/uuid": "^10.0.0",
    "firebase": "^11.9.1",
    "framer-motion": "^12.27.1",
    "libphonenumber-js": "^1.12.9",
    "next": "16.0.10",
    "next-themes": "^0.4.6",
    "react": "18.3.1",
    "react-country-flag": "^3.1.0",
    "react-dom": "18.3.1",
    "react-icons": "^5.5.0",
    "react-phone-input-2": "^2.15.1",
    "react-redux": "^9.2.0",
    "server-only": "^0.0.1",
    "stripe": "^18.2.1",
    "swiper": "^11.2.6",
    "uuid": "^13.0.0",
    "zod": "^4.1.13",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@tailwindcss/line-clamp": "^0.4.4",
    "@types/node": "^20.11.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.21",
    "cross-env": "^7.0.3",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.3.3"
  }
